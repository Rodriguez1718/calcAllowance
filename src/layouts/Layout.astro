---
import Toaster from '../components/Toaster.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="IDRIS Portal — Rendered Hours & Allowance Tracker." />
    <title>NTV — IDRIS Allowance Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <Toaster />
  </body>
</html>

<style is:global>
  :root {
    --ntv-bg: #050b16;
    --ntv-orange: #ed6621;
    --ntv-red: #e61e2a;
    --ntv-magenta: #a60b3f;
    --ntv-gradient: linear-gradient(90deg, #ed6621, #e61e2a);
    --ntv-gradient-alt: linear-gradient(90deg, #e61e2a, #a60b3f);
    --text-primary: #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.7);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --card-bg: rgba(13, 17, 30, 0.8);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--ntv-bg);
    color: var(--text-primary);
    overflow-x: hidden;
  }
</style>
