---
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';

// Check if user is logged in
const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

// If logged in, redirect to dashboard
if (user) {
  return Astro.redirect('/dashboard');
}
---
<Layout>
  <header id="sys-header">
    <div class="header-left">
      <div class="logo-mark">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L3 7V12C3 16.55 6.84 20.74 12 22C17.16 20.74 21 16.55 21 12V7L12 2Z" fill="url(#lg)"/>
          <path d="M9 12L11 14L15 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <defs>
            <linearGradient id="lg" x1="3" y1="2" x2="21" y2="22" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#6366f1"/><stop offset="100%" stop-color="#8b5cf6"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-primary">IDRIS</span>
        <span class="logo-sep">×</span>
        <span class="logo-secondary">Allowance</span>
      </div>
    </div>
    <div class="header-center">
      <div class="clock-wrapper">
        <span class="pulse-dot green"></span>
        <span id="live-clock" class="live-clock">--:--:-- --</span>
        <span class="clock-tz">PHT</span>
      </div>
    </div>
    <div class="header-right">
      <div class="status-pill">
        <span class="pulse-dot green"></span>
        <span class="status-on">System Online</span>
        <span class="sdiv">|</span>
        <span class="status-api">Clockify API Connected</span>
      </div>
    </div>
  </header>

  <div id="portal-body">
    <!-- SIDEBAR (Locked Preview) -->
    <aside id="sidebar">
      <div class="sidebar-lock">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="#6366f1" stroke-width="1.8"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="#6366f1" stroke-width="1.8" stroke-linecap="round"/></svg>
        <span>Login to unlock</span>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-item active-nav">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7"/></svg>
          <span>Dashboard</span>
        </div>
        <div class="nav-item">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M4 4v5h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 20v-5h-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M4.93 15a8 8 0 1 0 .67-8.37L4 11" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>Sync Logs</span>
        </div>
        <div class="nav-item">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          <span>Team Metrics</span>
        </div>
        <div class="nav-item">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.7"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z" stroke="currentColor" stroke-width="1.7"/></svg>
          <span>Settings</span>
        </div>
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-version">v1.0.4-stable</div>
      </div>
    </aside>

    <!-- MAIN STAGE -->
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="stage">
        <!-- TOP METRICS -->
        <div class="metrics-row">
          <div class="metric-card locked">
            <div class="metric-label">Active Rate</div>
            <div class="metric-value">₱60.00<span class="metric-unit"> / hr</span></div>
            <div class="metric-sub">Current multiplier</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="rgba(99,102,241,0.7)" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="rgba(99,102,241,0.7)" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
          <div class="metric-card locked">
            <div class="metric-label">Target Date</div>
            <div class="metric-value" id="countdown-val">--</div>
            <div class="metric-sub">May 12, 2026 · days left</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="rgba(99,102,241,0.7)" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="rgba(99,102,241,0.7)" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
        </div>

        <!-- COMMAND CARD -->
        <div id="command-card">
          <div class="card-eyebrow"><span class="eyebrow-dot"></span><span>Secure Portal Access</span></div>
          <h1 class="card-title">Log in to view your<br/><span class="card-accent">Rendered Hours & Allowance</span></h1>
          <p class="card-sub">Your personalized dashboard awaits. Sign in to access real-time data synced from Clockify.</p>
          <a href="/api/auth/google" id="google-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            <span>Continue with Google</span>
          </a>
          <div class="divider"><span class="dline"></span><span class="dtext">secured by</span><span class="dline"></span></div>
          <div class="sec-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7V12C3 16.55 6.84 20.74 12 22C17.16 20.74 21 16.55 21 12V7L12 2Z" stroke="#6366f1" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12L11 14L15 10" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Authenticated via <strong>Cebu Technological University</strong> Workspace · Official Team Portal</span>
          </div>
        </div>

        <!-- BOTTOM METRICS -->
        <div class="metrics-row">
          <div class="metric-card locked">
            <div class="metric-label">Total Program</div>
            <div class="metric-value">--- <span class="metric-unit">/ --- hrs</span></div>
            <div class="metric-sub">Login to view your data</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="rgba(99,102,241,0.7)" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="rgba(99,102,241,0.7)" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
          <div class="metric-card locked">
            <div class="metric-label">Team Status</div>
            <div class="metric-value">3<span class="metric-unit"> active</span></div>
            <div class="metric-sub">Developers online now</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="rgba(99,102,241,0.7)" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="rgba(99,102,241,0.7)" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function tick() {
    const pht = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' }));
    const h = pht.getHours(), m = String(pht.getMinutes()).padStart(2,'0'), s = String(pht.getSeconds()).padStart(2,'0');
    const ampm = h >= 12 ? 'PM' : 'AM';
    const el = document.getElementById('live-clock');
    if (el) el.textContent = `${String(h%12||12).padStart(2,'0')}:${m}:${s} ${ampm}`;
  }
  tick(); setInterval(tick, 1000);

  const target = new Date('2026-05-12T00:00:00+08:00');
  const days = Math.max(0, Math.ceil((target.getTime() - Date.now()) / 86400000));
  const cv = document.getElementById('countdown-val');
  if (cv) cv.textContent = days + ' days';
</script>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  /* HEADER */
  #sys-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 56px;
    background: rgba(9,10,18,0.88); backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(99,102,241,0.15);
  }
  .header-left { display: flex; align-items: center; gap: 10px; }
  .logo-mark {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.3); border-radius: 8px;
  }
  .logo-text { display: flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; }
  .logo-primary { color: #a5b4fc; font-weight: 700; letter-spacing: .08em; }
  .logo-sep { color: rgba(255,255,255,.22); font-weight: 300; }
  .logo-secondary { color: rgba(226,232,240,.6); font-weight: 400; }
  .clock-wrapper {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    border-radius: 20px; padding: 5px 14px;
  }
  .live-clock { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 500; color: #e2e8f0; letter-spacing: .06em; }
  .clock-tz { font-size: 10px; font-weight: 600; color: rgba(165,180,252,.7); letter-spacing: .1em; background: rgba(99,102,241,.15); padding: 2px 6px; border-radius: 4px; }
  .status-pill { display: flex; align-items: center; gap: 7px; background: rgba(52,211,153,.08); border: 1px solid rgba(52,211,153,.2); border-radius: 20px; padding: 5px 14px; font-size: 12px; }
  .pulse-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; animation: pdot 2s ease-in-out infinite; }
  .green { background: #34d399; box-shadow: 0 0 7px #34d399; }
  @keyframes pdot { 0%,100%{opacity:1} 50%{opacity:.35} }
  .status-on { font-weight: 600; color: #34d399; }
  .sdiv { color: rgba(255,255,255,.2); }
  .status-api { color: rgba(226,232,240,.55); font-size: 11px; }

  /* BODY */
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }

  /* SIDEBAR */
  #sidebar {
    position: fixed; left: 0; top: 56px; bottom: 0; width: 200px;
    background: rgba(10,11,22,0.82); backdrop-filter: blur(16px);
    border-right: 1px solid rgba(99,102,241,0.12);
    display: flex; flex-direction: column; padding: 20px 12px; gap: 6px;
  }
  .sidebar-lock {
    display: flex; align-items: center; gap: 6px; font-size: 10px;
    color: rgba(99,102,241,.7); letter-spacing: .06em; text-transform: uppercase;
    font-weight: 600; background: rgba(99,102,241,.07);
    border: 1px solid rgba(99,102,241,.15); border-radius: 6px;
    padding: 6px 10px; margin-bottom: 16px;
  }
  .sidebar-nav { display: flex; flex-direction: column; gap: 2px; }
  .nav-item {
    display: flex; align-items: center; gap: 11px; padding: 10px 12px;
    border-radius: 8px; font-size: 13px; font-weight: 500;
    color: rgba(148,163,184,.4); cursor: not-allowed;
    transition: background .2s; opacity: .55; filter: blur(0.4px);
  }
  .nav-item.active-nav { background: rgba(99,102,241,.1); color: rgba(165,180,252,.6); border: 1px solid rgba(99,102,241,.18); opacity: .65; }
  .sidebar-footer { margin-top: auto; padding: 0 4px; }
  .sidebar-version { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(100,116,139,.4); letter-spacing: .06em; }

  /* MAIN */
  #portal-main {
    margin-left: 200px; flex: 1; display: flex; align-items: center;
    justify-content: center; min-height: calc(100vh - 56px);
    position: relative; padding: 32px 24px;
  }
  .bg-grid {
    position: fixed; inset: 0;
    background-image: linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px);
    background-size: 40px 40px; pointer-events: none; z-index: 0;
  }
  .bg-glow {
    position: fixed; top: 30%; left: 55%; transform: translateX(-50%);
    width: 560px; height: 360px;
    background: radial-gradient(ellipse, rgba(99,102,241,.11) 0%, transparent 70%);
    pointer-events: none; z-index: 0;
  }

  /* STAGE */
  #stage {
    position: relative; z-index: 1; display: flex; flex-direction: column;
    align-items: center; gap: 16px; width: 100%; max-width: 820px;
  }
  .metrics-row { display: flex; gap: 16px; width: 100%; justify-content: center; }

  /* METRIC CARDS */
  .metric-card {
    flex: 1; max-width: 240px; min-width: 180px;
    background: rgba(13,14,26,.75); border: 1px solid rgba(99,102,241,.14);
    border-radius: 14px; padding: 18px 20px; position: relative; overflow: hidden;
  }
  .metric-card.locked { filter: blur(1.5px); opacity: .55; user-select: none; pointer-events: none; }
  .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: rgba(148,163,184,.55); margin-bottom: 8px; }
  .metric-value { font-size: 26px; font-weight: 700; color: #e2e8f0; letter-spacing: -.02em; line-height: 1; }
  .metric-unit { font-size: 13px; font-weight: 400; color: rgba(148,163,184,.6); }
  .metric-sub { font-size: 11px; color: rgba(100,116,139,.7); margin-top: 6px; }
  .lock-icon { position: absolute; top: 10px; right: 12px; opacity: .8; }

  /* COMMAND CARD */
  #command-card {
    width: 100%; max-width: 420px; background: rgba(13,14,26,.92);
    border: 1px solid rgba(99,102,241,.22); border-radius: 20px;
    padding: 36px 32px; backdrop-filter: blur(24px);
    box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset, 0 24px 80px rgba(0,0,0,.55), 0 0 60px rgba(99,102,241,.08);
    animation: cin .6s cubic-bezier(.16,1,.3,1) both;
  }
  @keyframes cin { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  .card-eyebrow { display: flex; align-items: center; gap: 7px; font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(165,180,252,.65); margin-bottom: 18px; }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: #6366f1; box-shadow: 0 0 6px #6366f1; }
  .card-title { font-size: 24px; font-weight: 700; line-height: 1.3; color: #f1f5f9; margin-bottom: 10px; }
  .card-accent { background: linear-gradient(135deg,#818cf8,#c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .card-sub { font-size: 13px; color: rgba(148,163,184,.75); line-height: 1.6; margin-bottom: 28px; }

  #google-btn {
    width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px;
    padding: 13px 20px; background: #fff; color: #1e1e2e;
    border: none; border-radius: 11px; font-family: 'Inter', sans-serif;
    font-size: 14px; font-weight: 600; cursor: pointer; transition: all .2s;
    box-shadow: 0 4px 20px rgba(0,0,0,.4); text-decoration: none;
  }
  #google-btn:hover { background: #f1f5f9; transform: translateY(-1px); box-shadow: 0 6px 28px rgba(0,0,0,.5); }
  #google-btn:active { transform: translateY(0); }

  .divider { display: flex; align-items: center; gap: 10px; margin: 22px 0 18px; }
  .dline { flex: 1; height: 1px; background: rgba(255,255,255,.07); }
  .dtext { font-size: 10px; color: rgba(148,163,184,.4); letter-spacing: .07em; text-transform: uppercase; white-space: nowrap; }

  .sec-badge {
    display: flex; align-items: flex-start; gap: 8px; padding: 11px 13px;
    background: rgba(99,102,241,.06); border: 1px solid rgba(99,102,241,.14);
    border-radius: 9px; font-size: 11.5px; color: rgba(148,163,184,.7); line-height: 1.5;
  }
  .sec-badge svg { flex-shrink: 0; margin-top: 1px; }
  .sec-badge strong { color: #a5b4fc; font-weight: 600; }

  @media (max-width: 640px) {
    #sidebar { display: none; }
    #portal-main { margin-left: 0; }
    .metrics-row { flex-wrap: wrap; }
    .metric-card { max-width: 100%; }
    #command-card { padding: 24px 18px; }
    .status-api, .logo-secondary, .logo-sep { display: none; }
  }
</style>
