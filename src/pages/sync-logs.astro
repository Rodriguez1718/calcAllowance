---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

// Fetch sync logs (mock for now or real if desired)
const syncLogs = [
  { id: 1, type: 'Sync', status: 'Success', date: '2026-05-01 10:45 AM', duration: '1.2s', details: 'Fetched 12 new time entries' },
  { id: 2, type: 'Auth', status: 'Success', date: '2026-05-01 10:40 AM', duration: '0.8s', details: 'Google OAuth session established' },
  { id: 3, type: 'Sync', status: 'Warning', date: '2026-04-30 09:12 PM', duration: '2.5s', details: 'Rate limit hit, partially synced' },
];
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="sync-logs" />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="logs-content">
        <div class="page-header">
          <h1>Sync Logs</h1>
          <p>Historical record of system sync events and authentication logs.</p>
        </div>

        <div class="logs-table-wrapper">
          <table class="logs-table">
            <thead>
              <tr>
                <th>Event Type</th>
                <th>Status</th>
                <th>Timestamp</th>
                <th>Duration</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {syncLogs.map(log => (
                <tr>
                  <td><span class={`type-pill ${log.type.toLowerCase()}`}>{log.type}</span></td>
                  <td><span class={`status-pill ${log.status.toLowerCase()}`}>{log.status}</span></td>
                  <td class="mono">{log.date}</td>
                  <td class="mono">{log.duration}</td>
                  <td class="details">{log.details}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 10%; left: 60%; transform: translateX(-50%); width: 600px; height: 400px; background: radial-gradient(ellipse, rgba(99,102,241,.07) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  
  #logs-content { position: relative; z-index: 1; max-width: 1000px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-size: 28px; font-weight: 700; color: #f1f5f9; margin-bottom: 6px; }
  .page-header p { font-size: 14px; color: rgba(148,163,184,.7); }

  .logs-table-wrapper { 
    background: rgba(13,14,26,.8); 
    border: 1px solid rgba(99,102,241,.16); 
    border-radius: 14px; 
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,.4);
  }
  .logs-table { width: 100%; border-collapse: collapse; text-align: left; }
  .logs-table th { padding: 16px 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(165,180,252,.7); border-bottom: 1px solid rgba(99,102,241,.12); background: rgba(99,102,241,.04); }
  .logs-table td { padding: 16px 20px; font-size: 13px; color: #cbd5e1; border-bottom: 1px solid rgba(99,102,241,.06); }
  .logs-table tr:hover { background: rgba(99,102,241,.03); }
  .logs-table tr:last-child td { border-bottom: none; }

  .mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: rgba(148,163,184,.8); }
  .details { color: rgba(148,163,184,.9); }

  .type-pill, .status-pill { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; }
  .type-pill.sync { background: rgba(99,102,241,.12); color: #a5b4fc; border: 1px solid rgba(99,102,241,.2); }
  .type-pill.auth { background: rgba(139,92,246,.12); color: #c4b5fd; border: 1px solid rgba(139,92,246,.2); }
  
  .status-pill.success { background: rgba(52,211,153,.1); color: #34d399; border: 1px solid rgba(52,211,153,.2); }
  .status-pill.warning { background: rgba(251,191,36,.1); color: #fbbf24; border: 1px solid rgba(251,191,36,.2); }

  @media (max-width: 640px) { #portal-main { margin-left: 0; padding: 24px 16px; } }
</style>
