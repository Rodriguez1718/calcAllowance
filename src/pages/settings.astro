---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings } from '../lib/settings';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings();
const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);
const success = Astro.url.searchParams.get('success') === 'true';
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="settings" />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="settings-content">
        <div class="page-header">
          <h1>Settings</h1>
          <p>Manage your account preferences and integration settings.</p>
        </div>

        <div class="settings-sections">
          <!-- Profile Section -->

          <section class="settings-card">
            <h2 class="card-title">Program Configuration</h2>
            <form action="/api/settings" method="POST" class="settings-form">
              <div class="form-row">
                <div class="form-group">
                  <label for="startDate">Program Start Date</label>
                  <input type="date" id="startDate" name="startDate" value={settings.startDate} required />
                  <p class="form-hint">Hours before this date will be ignored.</p>
                </div>
              </div>
              <div class="form-row split">
                <div class="form-group">
                  <label for="targetHours">Target Hours</label>
                  <div class="input-wrapper">
                    <input type="number" id="targetHours" name="targetHours" value={settings.targetHours} step="0.5" required />
                    <span class="input-suffix">hrs</span>
                  </div>
                </div>
                <div class="form-group">
                  <label for="hourlyRate">Hourly Rate</label>
                  <div class="input-wrapper">
                    <span class="input-prefix">₱</span>
                    <input type="number" id="hourlyRate" name="hourlyRate" value={settings.hourlyRate} step="0.5" required />
                  </div>
                </div>
              </div>
              <button type="submit" class="save-btn">Save Changes</button>
            </form>
          </section>

          <section class="settings-card">
            <h2 class="card-title">Profile Information</h2>
            <div class="profile-preview">
              {user.picture && <img src={user.picture} alt="" class="profile-img" />}
              <div class="profile-details">
                <div class="detail-group">
                  <label>Full Name</label>
                  <div class="read-only-box">{user.name}</div>
                </div>
                <div class="detail-group">
                  <label>Email Address</label>
                  <div class="read-only-box">{user.email}</div>
                </div>
              </div>
            </div>
          </section>

          <!-- Integration Section -->
          <section class="settings-card">
            <h2 class="card-title">Clockify Integration</h2>
            <div class="integration-status">
              <div class={`status-badge ${isClockifySet ? 'connected' : 'disconnected'}`}>
                {isClockifySet ? 'Connected' : 'Missing Credentials'}
              </div>
              <p class="status-desc">
                {isClockifySet 
                  ? 'Your system is currently syncing with Clockify using the environment variables provided.' 
                  : 'Update your .env file with CLOCKIFY_API_KEY and CLOCKIFY_WORKSPACE_ID to enable syncing.'}
              </p>
            </div>
            <div class="config-help">
              <div class="help-item">
                <span class="help-label">Sync Frequency</span>
                <span class="help-value">Real-time (On Request)</span>
              </div>
              <div class="help-item">
                <span class="help-label">Target Hours</span>
                <span class="help-value">480.00</span>
              </div>
            </div>
          </section>

          <!-- Danger Zone -->
          <section class="settings-card danger">
            <h2 class="card-title">Security</h2>
            <p class="danger-desc">Log out of all devices and end your current session.</p>
            <a href="/api/auth/logout" class="danger-btn">Sign Out Everywhere</a>
          </section>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  // Check for success or error in URL
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    window.showToast('Settings updated successfully!', 'success');
    // Clean up URL without refreshing
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
</script>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 10%; left: 80%; transform: translateX(-50%); width: 400px; height: 400px; background: radial-gradient(ellipse, rgba(99,102,241,.05) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  
  #settings-content { position: relative; z-index: 1; max-width: 800px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-size: 28px; font-weight: 700; color: #f1f5f9; margin-bottom: 6px; }
  .page-header p { font-size: 14px; color: rgba(148,163,184,.7); }

  .settings-sections { display: flex; flex-direction: column; gap: 24px; }
  .settings-card { 
    background: rgba(13,14,26,.8); 
    border: 1px solid rgba(99,102,241,.16); 
    border-radius: 16px; 
    padding: 28px;
  }
  .card-title { font-size: 16px; font-weight: 600; color: #a5b4fc; margin-bottom: 24px; }

  .profile-preview { display: flex; gap: 24px; align-items: flex-start; }
  .profile-img { width: 80px; height: 80px; border-radius: 50%; border: 3px solid rgba(99,102,241,.3); }
  .profile-details { flex: 1; display: flex; flex-direction: column; gap: 16px; }
  
  .detail-group label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: rgba(148,163,184,.5); margin-bottom: 6px; }
  .read-only-box { 
    padding: 12px 16px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); 
    border-radius: 8px; color: #e2e8f0; font-size: 14px; 
  }

  .status-badge { display: inline-flex; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-bottom: 12px; }
  .status-badge.connected { background: rgba(52,211,153,.15); color: #34d399; border: 1px solid rgba(52,211,153,.3); }
  .status-badge.disconnected { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.3); }
  .status-desc { font-size: 14px; color: rgba(148,163,184,.7); line-height: 1.6; margin-bottom: 24px; }

  .config-help { display: flex; gap: 32px; border-top: 1px solid rgba(255,255,255,.06); pt: 20px; }
  .help-item { display: flex; flex-direction: column; gap: 4px; }
  .help-label { font-size: 10px; font-weight: 600; color: rgba(148,163,184,.5); text-transform: uppercase; }
  .help-value { font-size: 13px; color: #cbd5e1; font-weight: 500; }

  .settings-card.danger { border-color: rgba(239,68,68,.2); }
  .danger-desc { font-size: 14px; color: rgba(148,163,184,.7); margin-bottom: 20px; }
  .danger-btn { 
    display: inline-flex; padding: 10px 20px; background: rgba(239,68,68,.1); 
    color: #f87171; border: 1px solid rgba(239,68,68,.3); border-radius: 8px;
    font-size: 13px; font-weight: 600; text-decoration: none; transition: all .2s;
  }
  .danger-btn:hover { background: rgba(239,68,68,.2); transform: translateY(-1px); }


  .settings-form { display: flex; flex-direction: column; gap: 20px; }
  .form-row.split { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-group label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: rgba(148,163,184,.5); }
  .form-hint { font-size: 11px; color: rgba(148,163,184,.4); margin-top: 2px; }

  input[type="date"], input[type="number"] {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px; padding: 12px 14px; color: #f1f5f9; font-size: 14px;
    transition: all 0.2s;
  }
  input:focus { outline: none; border-color: rgba(99,102,241,.5); background: rgba(255,255,255,.05); box-shadow: 0 0 0 3px rgba(99,102,241,.1); }

  .input-wrapper { position: relative; display: flex; align-items: center; }
  .input-wrapper input { width: 100%; }
  .input-prefix { position: absolute; left: 14px; color: rgba(148,163,184,.5); font-weight: 600; }
  .input-suffix { position: absolute; right: 14px; color: rgba(148,163,184,.5); font-size: 12px; }
  .input-wrapper .input-prefix + input { padding-left: 32px; }
  .input-wrapper input:has(+ .input-suffix) { padding-right: 48px; }

  .save-btn {
    align-self: flex-start;
    padding: 12px 24px; background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white; border: none; border-radius: 8px;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: all 0.2s;
  }
  .save-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99,102,241,0.3); }
  .save-btn:active { transform: translateY(0); }

  @media (max-width: 640px) { #portal-main { margin-left: 0; padding: 24px 16px; } .profile-preview { flex-direction: column; align-items: center; } .config-help { flex-direction: column; gap: 16px; } .form-row.split { grid-template-columns: 1fr; } }
</style>
