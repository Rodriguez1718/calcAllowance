---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getClockifyUser, getRenderedHours } from '../lib/clockify';

import { getAppSettings } from '../lib/settings';
import { getManualEntries } from '../lib/entries';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

// Fetch App Settings
const settings = await getAppSettings(user.id);
const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);

// Shared grouping logic for Earnings Breakdown
const groupEntries = (entries: any[], schedule: string) => {
  const map: Record<string, { label: string, seconds: number, days: Set<string>, sortKey: string }> = {};
  
  entries.forEach(e => {
    const d = new Date(e.date);
    let key = '';
    let label = '';
    let sortKey = '';
    
    if (schedule === 'weekly') {
      const firstDayOfYear = new Date(d.getFullYear(), 0, 1);
      const pastDaysOfYear = (d.getTime() - firstDayOfYear.getTime()) / 86400000;
      const weekNum = Math.ceil((pastDaysOfYear + firstDayOfYear.getDay() + 1) / 7);
      key = `${d.getFullYear()}-W${weekNum}`;
      label = `Week ${weekNum}, ${d.getFullYear()}`;
      sortKey = key;
    } else if (schedule === 'semi-monthly') {
      const day = d.getDate();
      let paydayMonth = d.getMonth();
      let paydayYear = d.getFullYear();
      let period = '';

      let periodStart = '';
      let periodEnd = '';

      if (day >= 30) {
        // 30th and 31st belong to the 15th payday of the NEXT month
        paydayMonth += 1;
        period = "15th";
        const prevMonth = new Date(paydayYear, paydayMonth - 1, 30);
        const currMonthEnd = new Date(paydayYear, paydayMonth, 14);
        periodStart = prevMonth.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        periodEnd = currMonthEnd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      } else if (day >= 15) {
        // 15th to 29th belong to the 30th payday of the CURRENT month
        period = "30th";
        const currMonthStart = new Date(paydayYear, paydayMonth, 15);
        const currMonthEnd = new Date(paydayYear, paydayMonth, 29);
        periodStart = currMonthStart.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        periodEnd = currMonthEnd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      } else {
        // 1st to 14th belong to the 15th payday of the CURRENT month
        period = "15th";
        const prevMonth = new Date(paydayYear, paydayMonth - 1, 30);
        const currMonthEnd = new Date(paydayYear, paydayMonth, 14);
        periodStart = prevMonth.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        periodEnd = currMonthEnd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      // Handle year overflow
      if (paydayMonth > 11) {
        paydayMonth = 0;
        paydayYear += 1;
      }

      const paydayDate = new Date(paydayYear, paydayMonth, period === "15th" ? 15 : 30);
      label = `${periodStart} - ${periodEnd} (Payday: ${paydayDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })})`;
      sortKey = `${paydayYear}-${String(paydayMonth + 1).padStart(2, '0')}-${period === "15th" ? '1' : '2'}`;
      key = sortKey;
    } else {
      key = e.date.substring(0, 7);
      label = d.toLocaleString('en-US', { month: 'long', year: 'numeric' });
      sortKey = key;
    }
    
    if (!map[key]) map[key] = { label, seconds: 0, days: new Set(), sortKey };
    map[key].seconds += e.durationSeconds;
    map[key].days.add(e.date);
  });
  
  return Object.values(map).sort((a, b) => b.sortKey.localeCompare(a.sortKey));
};

// Fetch data (Clockify or Manual)
let renderedHours = 0;
let monthlyData = [];
let clockifyError = null;
let isUsingManual = false;
let allRawEntries = [];
let activeTimer = null;

if (isClockifySet) {
  try {
    const { getActiveTimer } = await import('../lib/clockify');
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      // Fetch both completed and active timer
      const [data, active] = await Promise.all([
        getRenderedHours(clockifyUser.id, settings.startDate),
        getActiveTimer(clockifyUser.id)
      ]);
      
      renderedHours = data.totalHours;
      allRawEntries = data.entries;
      activeTimer = active;

      if (activeTimer) {
        // Add active timer to total hours
        const activeHours = activeTimer.elapsedSeconds / 3600;
        renderedHours += activeHours;
        
        // Add to entries for breakdown calculation (today's date in Manila)
        const isoDate = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' });
        allRawEntries.push({ date: isoDate, durationSeconds: activeTimer.elapsedSeconds });
      }
    } else {
      isUsingManual = true;
    }
  } catch (err) {
    console.error('Clockify sync error:', err);
    clockifyError = err.message;
    isUsingManual = true; 
  }
} else {
  isUsingManual = true;
}

if (isUsingManual) {
  const manualEntries = await getManualEntries(user.id);
  allRawEntries = manualEntries
    .filter(e => new Date(e.date) >= new Date(settings.startDate))
    .map(e => ({ date: e.date, durationSeconds: e.durationSeconds }));
  
  renderedHours = allRawEntries.reduce((acc, e) => acc + e.durationSeconds, 0) / 3600;
}

// Apply grouping to whatever entries we have
const grouped = groupEntries(allRawEntries, settings.paySchedule);
monthlyData = grouped.map(item => ({
  label: item.label,
  hours: item.seconds / 3600,
  days: item.days.size
}));

// Compute countdown (using static target for now, or could add targetDate to settings)
const targetDate = new Date('2026-05-12T00:00:00+08:00');
const now = new Date();
const daysLeft = Math.max(0, Math.ceil((targetDate.getTime() - now.getTime()) / 86400000));

const formatHMS = (totalSeconds: number) => {
  const h = Math.floor(totalSeconds / 3600);
  const m = Math.floor((totalSeconds % 3600) / 60);
  const s = Math.floor(totalSeconds % 60);
  return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
};

const formatTo12hr = (timeStr: string) => {
  if (!timeStr) return '';
  const [h, m] = timeStr.split(':').map(Number);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const hour = h % 12 || 12;
  return `${hour}:${String(m).padStart(2, '0')} ${ampm}`;
};

// Fetch recent activity (Clockify or Manual)
let activity = [];
if (!isUsingManual) {
  try {
    const { getRecentEntries } = await import('../lib/clockify');
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      activity = await getRecentEntries(clockifyUser.id);
    }
  } catch (err) {
    console.error('Activity sync error:', err);
  }
} else {
  // Manual Activity
  const manualEntries = await getManualEntries(user.id);
  activity = manualEntries
    .sort((a, b) => b.date.localeCompare(a.date))
    .slice(0, 4)
    .map(e => ({
      description: e.description,
      startTime: `${e.date} ${formatTo12hr(e.startTime)}`,
      duration: e.durationSeconds
    }));
}
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="dashboard" />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      {/* SETUP WIZARD MODAL */}
      {!settings.setupComplete && (
        <div class="setup-overlay">
          <div class="setup-modal">
            <div class="modal-header">
              <div class="modal-badge">INITIAL SETUP</div>
              <h2>Configure Your Program</h2>
              <p>Welcome! Let's set up your internship details to get your dashboard ready.</p>
            </div>
            
            <form action="/api/settings" method="POST" class="setup-form" id="setup-wizard">
              <input type="hidden" name="setupComplete" value="true" />
              <input type="hidden" name="redirect" value="/dashboard" />
              
              <div class="form-group">
                <label>Target Hours</label>
                <div class="input-wrapper">
                  <input type="number" name="targetHours" value={settings.targetHours} required step="0.1" placeholder="e.g. 480" />
                  <span class="input-unit">HRS</span>
                </div>
              </div>

              <div class="form-group">
                <label class="check-label">
                  <input type="checkbox" name="hasAllowance" value="true" checked={settings.hasAllowance} id="allowance-toggle" />
                  <span>This internship offers an allowance</span>
                </label>
              </div>
              
              <div id="allowance-fields" style={settings.hasAllowance ? "" : "display: none;"}>
                <div class="form-row split">
                  <div class="form-group">
                    <label>Pay Model</label>
                    <select name="payType" class="setup-select">
                      <option value="hourly" selected={settings.payType === 'hourly'}>Hourly Rate</option>
                      <option value="daily" selected={settings.payType === 'daily'}>Fixed Daily Rate</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>Rate (₱)</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">₱</span>
                      <input type="number" name="hourlyRate" value={settings.hourlyRate} required step="0.01" placeholder="e.g. 60.00" />
                    </div>
                  </div>
                </div>

                <div class="form-group">
                  <label>Pay Schedule</label>
                  <select name="paySchedule" class="setup-select">
                    <option value="weekly" selected={settings.paySchedule === 'weekly'}>Every Week</option>
                    <option value="semi-monthly" selected={settings.paySchedule === 'semi-monthly'}>Every 15th / 30th (Semi-monthly)</option>
                    <option value="monthly" selected={settings.paySchedule === 'monthly'}>Monthly</option>
                  </select>
                </div>
              </div>
              
              <div class="form-group">
                <label>Program Start Date</label>
                <input type="date" name="startDate" value={settings.startDate} required />
              </div>
              
              <button type="submit" class="btn-setup">Save & Initialize Dashboard</button>
            </form>

            <script is:inline>
              document.getElementById('allowance-toggle')?.addEventListener('change', (e) => {
                const fields = document.getElementById('allowance-fields');
                if (fields) fields.style.display = e.target.checked ? 'block' : 'none';
              });
            </script>
          </div>
        </div>
      )}

      <div id="dash-content" class="content-center">
        <div class="dash-greeting">
          <div class="greeting-left">
            <h1>Welcome back, <span class="accent">{user.name?.split(' ')[0]}</span></h1>
            <p>Here's your progress overview for the current internship cycle.</p>
          </div>
          <div class="sync-status">
            <span class="sync-dot"></span>
            Real-time Sync Active
          </div>
        </div>

        {activeTimer && (
          <div class="active-timer-banner">
            <div class="timer-info">
              <span class="pulse-ring"></span>
              <div class="timer-details">
                <span class="timer-label">CURRENTLY LOGGING</span>
                <span class="timer-desc">{activeTimer.description}</span>
              </div>
            </div>
            <div class="timer-stats">
              <div class="timer-stat">
                <span class="stat-label">Elapsed</span>
                <span class="stat-val">{(activeTimer.elapsedSeconds / 3600).toFixed(2)}h</span>
              </div>
              <a href="/tracker" class="timer-link">View Tracker</a>
            </div>
          </div>
        )}

        <div class="progress-section">
          <div class="progress-header">
            <span class="progress-label">PROGRAM COMPLETION</span>
            <span class="progress-percent">{Math.min(100, (renderedHours / settings.targetHours) * 100).toFixed(1)}%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" style={`width: ${Math.min(100, (renderedHours / settings.targetHours) * 100)}%`}></div>
          </div>
        </div>

        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-label">Active Rate</div>
            <div class="metric-value">₱{settings.hourlyRate.toFixed(2)}<span class="metric-unit"> / hr</span></div>
            <div class="metric-sub">Current multiplier · updated weekly</div>
          </div>
          <div class="metric-card highlight">
            <div class="metric-label">Time Remaining</div>
            <div class="metric-value">{formatHMS(Math.max(0, (settings.targetHours * 3600) - (renderedHours * 3600)))}</div>
            <div class="metric-sub">
              {(() => {
                const remaining = Math.max(0, settings.targetHours - renderedHours);
                const workDaysNeeded = Math.ceil(remaining / 8);
                const finishDate = new Date();
                // Basic estimation adding work days (simple flat addition for now)
                finishDate.setDate(finishDate.getDate() + workDaysNeeded);
                return `Est. Finish: ${finishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
              })()}
            </div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Your Progress</div>
            <div class="metric-value">{formatHMS(renderedHours * 3600)}</div>
            <div class="metric-sub">{clockifyError ? <span class="error-text">{clockifyError}</span> : `Target: ${settings.targetHours} hrs`}</div>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">
            Earnings Breakdown 
            <span class="schedule-badge">{settings.paySchedule}</span>
          </h2>
          <div class="table-wrapper">
            <table class="breakdown-table">
              <thead>
                <tr>
                  <th>Period</th>
                  <th>{settings.payType === 'hourly' ? 'Hours Rendered' : 'Days Attended'}</th>
                  {settings.hasAllowance && <th>Total Estimate</th>}
                </tr>
              </thead>
              <tbody>
                {monthlyData.length > 0 ? (
                  monthlyData.map((item) => (
                    <tr>
                      <td class="month-name">{item.label}</td>
                      <td class="mono">{settings.payType === 'hourly' ? `${item.hours.toFixed(2)} hrs` : `${item.days} days`}</td>
                      {settings.hasAllowance && (
                        <td class="mono allowance-val">
                          ₱{(settings.payType === 'hourly' ? item.hours * settings.hourlyRate : item.days * settings.hourlyRate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                        </td>
                      )}
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colspan={settings.hasAllowance ? 3 : 2} class="empty-state">No time entries found for the selected period.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">Recent Activity</h2>
          <div class="activity-list">
            {activity.length > 0 ? activity.map(item => (
              <div class="activity-item">
                <div class="activity-dot"></div>
                <div class="activity-content">
                  <div class="activity-text">{item.description || 'Working on tasks'}</div>
                  <div class="activity-time">{item.startTime} • {(item.duration / 3600).toFixed(2)}h</div>
                </div>
              </div>
            )) : (
              <div class="activity-item">
                <div class="activity-dot muted"></div>
                <div class="activity-content">
                  <div class="activity-text">No recent activity found</div>
                  <div class="activity-time">Once you log time, it will appear here.</div>
                </div>
              </div>
            )}
            
            <div class="activity-item">
              <div class="activity-dot muted"></div>
              <div class="activity-content">
                <div class="activity-text">Session started via Google Auth</div>
                <div class="activity-time">System • Active</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(237, 102, 33, .04) 1px, transparent 1px), linear-gradient(90deg, rgba(237, 102, 33, .04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 20%; left: 55%; transform: translateX(-50%); width: 560px; height: 360px; background: radial-gradient(ellipse, rgba(237, 102, 33, 0.08) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  #dash-content { position: relative; z-index: 1; max-width: 900px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  .dash-greeting { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
  .dash-greeting h1 { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
  .dash-greeting p { font-size: 14px; color: var(--text-secondary); }
  .sync-status { display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; color: #34d399; background: rgba(52, 211, 153, 0.08); padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(52, 211, 153, 0.2); }
  .sync-dot { width: 6px; height: 6px; background: #34d399; border-radius: 50%; box-shadow: 0 0 8px #34d399; }
  .accent { background: var(--ntv-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .active-timer-banner { 
    display: flex; justify-content: space-between; align-items: center; 
    background: rgba(237, 102, 33, 0.1); border: 1px solid rgba(237, 102, 33, 0.3);
    border-radius: 16px; padding: 16px 24px; margin-bottom: 24px;
    animation: slideDown .4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  
  .timer-info { display: flex; align-items: center; gap: 16px; }
  .pulse-ring { 
    width: 10px; height: 10px; background: var(--ntv-orange); border-radius: 50%; 
    position: relative; box-shadow: 0 0 10px var(--ntv-orange);
  }
  .pulse-ring::after { 
    content: ''; position: absolute; inset: -4px; border-radius: 50%; 
    border: 2px solid var(--ntv-orange); animation: ringPulse 1.5s ease-out infinite; 
  }
  @keyframes ringPulse { 0% { transform: scale(1); opacity: 0.6; } 100% { transform: scale(2.5); opacity: 0; } }
  
  .timer-details { display: flex; flex-direction: column; }
  .timer-label { font-size: 10px; font-weight: 700; color: var(--ntv-orange); letter-spacing: 0.1em; }
  .timer-desc { font-size: 14px; font-weight: 500; color: #fff; }
  
  .timer-stats { display: flex; align-items: center; gap: 24px; }
  .timer-stat { display: flex; flex-direction: column; align-items: flex-end; }
  .stat-label { font-size: 10px; color: var(--text-secondary); }
  .stat-val { font-size: 16px; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; }
  .timer-link { font-size: 12px; font-weight: 700; color: #fff; text-decoration: none; background: rgba(255, 255, 255, 0.1); padding: 8px 16px; border-radius: 8px; transition: all 0.2s; }
  .timer-link:hover { background: rgba(255, 255, 255, 0.15); transform: translateX(2px); }
  
  .progress-section { margin-bottom: 32px; background: var(--card-bg); padding: 20px 24px; border-radius: 14px; border: 1px solid var(--border-subtle); }
  .progress-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 12px; }
  .progress-label { font-size: 11px; font-weight: 700; color: var(--text-secondary); letter-spacing: 0.1em; }
  .progress-percent { font-size: 18px; font-weight: 800; color: var(--ntv-orange); font-family: 'JetBrains Mono', monospace; }
  .progress-track { width: 100%; height: 8px; background: rgba(255, 255, 255, 0.05); border-radius: 10px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--ntv-gradient); border-radius: 10px; box-shadow: 0 0 15px rgba(237, 102, 33, 0.3); transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); }

  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 16px; margin-bottom: 36px; }
  .metric-card { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 14px; padding: 20px 22px; transition: border-color .2s, transform .2s; }
  .metric-card:hover { border-color: var(--ntv-orange); transform: translateY(-2px); }
  .metric-card.highlight { border-color: rgba(237, 102, 33, 0.4); background: rgba(237, 102, 33, 0.04); box-shadow: 0 0 20px rgba(237, 102, 33, 0.05); }
  .metric-card.highlight .metric-value { color: var(--ntv-orange); }
  .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 10px; }
  .metric-value { font-size: 28px; font-weight: 700; color: var(--text-primary); letter-spacing: -.02em; line-height: 1; }
  .metric-unit { font-size: 13px; font-weight: 400; color: var(--text-secondary); }
  .metric-sub { font-size: 11px; color: var(--text-secondary); margin-top: 8px; }
  .section-title { display: flex; align-items: center; justify-content: space-between; font-size: 15px; font-weight: 600; color: var(--ntv-orange); letter-spacing: .04em; margin-bottom: 16px; }
  .schedule-badge { font-size: 9px; padding: 2px 8px; background: rgba(237, 102, 33, 0.1); border: 1px solid rgba(237, 102, 33, 0.2); border-radius: 4px; text-transform: uppercase; color: var(--ntv-orange); }
  .activity-list { display: flex; flex-direction: column; gap: 0; }
  .activity-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: rgba(5, 11, 22, 0.6); border: 1px solid var(--border-subtle); border-bottom: none; transition: background .15s; }
  .activity-item:first-child { border-radius: 12px 12px 0 0; }
  .activity-item:last-child { border-radius: 0 0 12px 12px; border-bottom: 1px solid var(--border-subtle); }
  .activity-item:hover { background: rgba(237, 102, 33, 0.06); }
  .activity-dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,.4); flex-shrink: 0; }
  .activity-dot.muted { background: rgba(255, 255, 255, 0.1); box-shadow: none; }
  .activity-content { display: flex; justify-content: space-between; flex: 1; align-items: center; }
  .activity-text { font-size: 13px; color: var(--text-primary); }
  .activity-time { font-size: 11px; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }
  .error-text { color: #f87171; }

  .activity-section { margin-bottom: 32px; }
  .table-wrapper { 
    background: var(--card-bg); 
    border: 1px solid var(--border-subtle); 
    border-radius: 14px; 
    overflow: hidden;
  }
  .breakdown-table { width: 100%; border-collapse: collapse; text-align: left; }
  .breakdown-table th { 
    padding: 14px 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; 
    letter-spacing: .05em; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.02);
  }
