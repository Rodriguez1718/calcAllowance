---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getClockifyUser, getRenderedHours } from '../lib/clockify';

import { getAppSettings } from '../lib/settings';
import { getManualEntries } from '../lib/entries';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

// Fetch App Settings
const settings = await getAppSettings(user.id);
const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);

// Fetch data (Clockify or Manual)
let renderedHours = 0;
let monthlyData = [];
let clockifyError = null;
let isUsingManual = false;

if (isClockifySet) {
  try {
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      const data = await getRenderedHours(clockifyUser.id, settings.startDate);
      renderedHours = data.totalHours;
      monthlyData = data.monthlyBreakdown;
    } else {
      isUsingManual = true;
    }
  } catch (err) {
    console.error('Clockify sync error:', err);
    clockifyError = err.message;
    isUsingManual = true; // Fallback on error too
  }
} else {
  isUsingManual = true;
}

if (isUsingManual) {
  // Manual Fallback
  const manualEntries = await getManualEntries(user.id);
  const filtered = manualEntries.filter(e => new Date(e.date) >= new Date(settings.startDate));
  renderedHours = filtered.reduce((acc, e) => acc + e.durationSeconds, 0) / 3600;
  
  // Group manual entries by month for the table
  const monthlyMap: Record<string, number> = {};
  filtered.forEach(e => {
    const monthKey = e.date.substring(0, 7); // YYYY-MM
    monthlyMap[monthKey] = (monthlyMap[monthKey] || 0) + e.durationSeconds;
  });
  monthlyData = Object.entries(monthlyMap).map(([month, seconds]) => ({
    month,
    hours: seconds / 3600
  })).sort((a,b) => b.month.localeCompare(a.month));
}

// Compute countdown (using static target for now, or could add targetDate to settings)
const targetDate = new Date('2026-05-12T00:00:00+08:00');
const now = new Date();
const daysLeft = Math.max(0, Math.ceil((targetDate.getTime() - now.getTime()) / 86400000));

const formatTo12hr = (timeStr: string) => {
  if (!timeStr) return '';
  const [h, m] = timeStr.split(':').map(Number);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const hour = h % 12 || 12;
  return `${hour}:${String(m).padStart(2, '0')} ${ampm}`;
};

// Fetch recent activity (Clockify or Manual)
let activity = [];
if (!isUsingManual) {
  try {
    const { getRecentEntries } = await import('../lib/clockify');
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      activity = await getRecentEntries(clockifyUser.id);
    }
  } catch (err) {
    console.error('Activity sync error:', err);
  }
} else {
  // Manual Activity
  const manualEntries = await getManualEntries(user.id);
  activity = manualEntries
    .sort((a, b) => b.date.localeCompare(a.date))
    .slice(0, 4)
    .map(e => ({
      description: e.description,
      startTime: `${e.date} ${formatTo12hr(e.startTime)}`,
      duration: e.durationSeconds
    }));
}
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="dashboard" />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      {/* SETUP WIZARD MODAL */}
      {!settings.setupComplete && (
        <div class="setup-overlay">
          <div class="setup-modal">
            <div class="modal-header">
              <div class="modal-badge">INITIAL SETUP</div>
              <h2>Configure Your Program</h2>
              <p>Welcome! Let's set up your internship details to get your dashboard ready.</p>
            </div>
            
            <form action="/api/settings" method="POST" class="setup-form">
              <input type="hidden" name="setupComplete" value="true" />
              <input type="hidden" name="redirect" value="/dashboard" />
              
              <div class="form-group">
                <label>Target Hours</label>
                <div class="input-wrapper">
                  <input type="number" name="targetHours" value={settings.targetHours} required step="0.1" placeholder="e.g. 480" />
                  <span class="input-unit">HRS</span>
                </div>
              </div>
              
              <div class="form-group">
                <label>Hourly Allowance</label>
                <div class="input-wrapper">
                  <span class="input-prefix">₱</span>
                  <input type="number" name="hourlyRate" value={settings.hourlyRate} required step="0.01" placeholder="e.g. 60.00" />
                </div>
              </div>
              
              <div class="form-group">
                <label>Program Start Date</label>
                <input type="date" name="startDate" value={settings.startDate} required />
              </div>
              
              <button type="submit" class="btn-setup">Save & Initialize Dashboard</button>
            </form>
          </div>
        </div>
      )}

      <div id="dash-content">
        <div class="dash-greeting">
          <h1>Welcome back, <span class="accent">{user.name?.split(' ')[0]}</span></h1>
          <p>Here's your progress overview for the current internship cycle.</p>
        </div>

        <div class="progress-section">
          <div class="progress-header">
            <span class="progress-label">PROGRAM COMPLETION</span>
            <span class="progress-percent">{Math.min(100, (renderedHours / settings.targetHours) * 100).toFixed(1)}%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" style={`width: ${Math.min(100, (renderedHours / settings.targetHours) * 100)}%`}></div>
          </div>
        </div>

        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-label">Active Rate</div>
            <div class="metric-value">₱{settings.hourlyRate.toFixed(2)}<span class="metric-unit"> / hr</span></div>
            <div class="metric-sub">Current multiplier · updated weekly</div>
          </div>
          <div class="metric-card highlight">
            <div class="metric-label">Hours Remaining</div>
            <div class="metric-value">{Math.max(0, settings.targetHours - renderedHours).toFixed(1)}<span class="metric-unit"> hrs</span></div>
            <div class="metric-sub">
              {(() => {
                const remaining = Math.max(0, settings.targetHours - renderedHours);
                const workDaysNeeded = Math.ceil(remaining / 8);
                const finishDate = new Date();
                // Basic estimation adding work days (simple flat addition for now)
                finishDate.setDate(finishDate.getDate() + workDaysNeeded);
                return `Est. Finish: ${finishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
              })()}
            </div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Your Progress</div>
            <div class="metric-value">{renderedHours.toFixed(1)}<span class="metric-unit"> / {settings.targetHours} hrs</span></div>
            <div class="metric-sub">{clockifyError ? <span class="error-text">{clockifyError}</span> : `Logged since ${new Date(settings.startDate).toLocaleDateString()}`}</div>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">Monthly Breakdown</h2>
          <div class="table-wrapper">
            <table class="breakdown-table">
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Hours Rendered</th>
                  <th>Total Estimate</th>
                </tr>
              </thead>
              <tbody>
                {monthlyData.length > 0 ? (
                  monthlyData.map((item) => (
                    <tr>
                      <td class="month-name">
                        {new Date(item.month + '-02').toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                      </td>
                      <td class="mono">{item.hours.toFixed(2)} hrs</td>
                      <td class="mono allowance-val">₱{(item.hours * settings.hourlyRate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colspan="3" class="empty-state">No time entries found for the selected period.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">Recent Activity</h2>
          <div class="activity-list">
            {activity.length > 0 ? activity.map(item => (
              <div class="activity-item">
                <div class="activity-dot"></div>
                <div class="activity-content">
                  <div class="activity-text">{item.description || 'Working on tasks'}</div>
                  <div class="activity-time">{item.startTime} • {(item.duration / 3600).toFixed(2)}h</div>
                </div>
              </div>
            )) : (
              <div class="activity-item">
                <div class="activity-dot muted"></div>
                <div class="activity-content">
                  <div class="activity-text">No recent activity found</div>
                  <div class="activity-time">Once you log time, it will appear here.</div>
                </div>
              </div>
            )}
            
            <div class="activity-item">
              <div class="activity-dot muted"></div>
              <div class="activity-content">
                <div class="activity-text">Session started via Google Auth</div>
                <div class="activity-time">System • Active</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(237, 102, 33, .04) 1px, transparent 1px), linear-gradient(90deg, rgba(237, 102, 33, .04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 20%; left: 55%; transform: translateX(-50%); width: 560px; height: 360px; background: radial-gradient(ellipse, rgba(237, 102, 33, 0.08) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  #dash-content { position: relative; z-index: 1; max-width: 900px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  .dash-greeting { margin-bottom: 32px; }
  .dash-greeting h1 { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
  .dash-greeting p { font-size: 14px; color: var(--text-secondary); }
  .accent { background: var(--ntv-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  
  .progress-section { margin-bottom: 32px; background: var(--card-bg); padding: 20px 24px; border-radius: 14px; border: 1px solid var(--border-subtle); }
  .progress-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 12px; }
  .progress-label { font-size: 11px; font-weight: 700; color: var(--text-secondary); letter-spacing: 0.1em; }
  .progress-percent { font-size: 18px; font-weight: 800; color: var(--ntv-orange); font-family: 'JetBrains Mono', monospace; }
  .progress-track { width: 100%; height: 8px; background: rgba(255, 255, 255, 0.05); border-radius: 10px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--ntv-gradient); border-radius: 10px; box-shadow: 0 0 15px rgba(237, 102, 33, 0.3); transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); }

  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 16px; margin-bottom: 36px; }
  .metric-card { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 14px; padding: 20px 22px; transition: border-color .2s, transform .2s; }
  .metric-card:hover { border-color: var(--ntv-orange); transform: translateY(-2px); }
  .metric-card.highlight { border-color: rgba(237, 102, 33, 0.4); background: rgba(237, 102, 33, 0.04); box-shadow: 0 0 20px rgba(237, 102, 33, 0.05); }
  .metric-card.highlight .metric-value { color: var(--ntv-orange); }
  .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 10px; }
  .metric-value { font-size: 28px; font-weight: 700; color: var(--text-primary); letter-spacing: -.02em; line-height: 1; }
  .metric-unit { font-size: 13px; font-weight: 400; color: var(--text-secondary); }
  .metric-sub { font-size: 11px; color: var(--text-secondary); margin-top: 8px; }
  .section-title { font-size: 15px; font-weight: 600; color: var(--ntv-orange); letter-spacing: .04em; margin-bottom: 16px; }
  .activity-list { display: flex; flex-direction: column; gap: 0; }
  .activity-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: rgba(5, 11, 22, 0.6); border: 1px solid var(--border-subtle); border-bottom: none; transition: background .15s; }
  .activity-item:first-child { border-radius: 12px 12px 0 0; }
  .activity-item:last-child { border-radius: 0 0 12px 12px; border-bottom: 1px solid var(--border-subtle); }
  .activity-item:hover { background: rgba(237, 102, 33, 0.06); }
  .activity-dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,.4); flex-shrink: 0; }
  .activity-dot.muted { background: rgba(255, 255, 255, 0.1); box-shadow: none; }
  .activity-content { display: flex; justify-content: space-between; flex: 1; align-items: center; }
  .activity-text { font-size: 13px; color: var(--text-primary); }
  .activity-time { font-size: 11px; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }
  .error-text { color: #f87171; }

  .activity-section { margin-bottom: 32px; }
  .table-wrapper { 
    background: var(--card-bg); 
    border: 1px solid var(--border-subtle); 
    border-radius: 14px; 
    overflow: hidden;
  }
  .breakdown-table { width: 100%; border-collapse: collapse; text-align: left; }
  .breakdown-table th { 
    padding: 14px 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; 
    letter-spacing: .05em; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.02);
  }
  .breakdown-table td { padding: 16px 20px; font-size: 14px; color: var(--text-primary); border-bottom: 1px solid var(--border-subtle); }
  .breakdown-table tr:last-child td { border-bottom: none; }
  .breakdown-table tr:hover { background: rgba(237, 102, 33, 0.02); }
  
  .month-name { font-weight: 600; color: var(--text-primary); }
  .mono { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .allowance-val { color: #34d399; font-weight: 600; }
  .empty-state { text-align: center; padding: 32px; color: var(--text-secondary); font-size: 13px; }
  
  /* MODAL STYLES */
  .setup-overlay { position: fixed; inset: 0; background: rgba(5, 11, 22, 0.85); backdrop-filter: blur(8px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .setup-modal { background: #0d1421; border: 1px solid rgba(237, 102, 33, 0.3); border-radius: 20px; width: 100%; max-width: 440px; padding: 40px; box-shadow: 0 20px 80px rgba(0,0,0,0.6), 0 0 40px rgba(237, 102, 33, 0.1); animation: modalIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
  @keyframes modalIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
  
  .modal-header { text-align: center; margin-bottom: 32px; }
  .modal-badge { display: inline-block; padding: 4px 10px; background: rgba(237, 102, 33, 0.15); color: var(--ntv-orange); font-size: 10px; font-weight: 700; border-radius: 4px; letter-spacing: 0.1em; margin-bottom: 12px; }
  .modal-header h2 { font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .modal-header p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
  
  .setup-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-group label { font-size: 12px; font-weight: 600; color: var(--text-secondary); }
  
  .input-wrapper { position: relative; display: flex; align-items: center; }
  .input-prefix, .input-unit { position: absolute; font-size: 13px; font-weight: 600; color: var(--text-secondary); }
  .input-prefix { left: 14px; }
  .input-unit { right: 14px; color: var(--ntv-orange); }
  
  .setup-form input { width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-subtle); border-radius: 10px; padding: 12px 14px; color: #fff; font-size: 15px; font-family: 'Outfit', sans-serif; transition: all 0.2s; }
  .setup-form input:focus { outline: none; border-color: var(--ntv-orange); background: rgba(237, 102, 33, 0.04); }
  .setup-form .input-prefix + input { padding-left: 32px; }
  .setup-form input[type="date"] { color-scheme: dark; }
  
  .btn-setup { margin-top: 10px; background: var(--ntv-gradient); border: none; border-radius: 10px; padding: 14px; color: #fff; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(237, 102, 33, 0.3); }
  .btn-setup:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(237, 102, 33, 0.4); filter: brightness(1.1); }
  .btn-setup:active { transform: translateY(0); }

  @media (max-width: 640px) { #portal-main { margin-left: 0; padding: 24px 16px; } .metrics-grid { grid-template-columns: 1fr; } .setup-modal { padding: 30px 20px; } }
</style>
