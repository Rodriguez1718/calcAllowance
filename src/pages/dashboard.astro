---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getClockifyUser, getRenderedHours } from '../lib/clockify';

import { getAppSettings } from '../lib/settings';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

// Fetch App Settings
const settings = await getAppSettings();

// Fetch Clockify data
let renderedHours = 0;
let monthlyData = [];
let clockifyError = null;

try {
  const clockifyUser = await getClockifyUser(user.email);
  if (clockifyUser) {
    const data = await getRenderedHours(clockifyUser.id, settings.startDate);
    renderedHours = data.totalHours;
    monthlyData = data.monthlyBreakdown;
  } else {
    clockifyError = 'User not found in Clockify workspace';
  }
} catch (err) {
  console.error('Clockify sync error:', err);
  clockifyError = err.message;
}

// Compute countdown (using static target for now, or could add targetDate to settings)
const targetDate = new Date('2026-05-12T00:00:00+08:00');
const now = new Date();
const daysLeft = Math.max(0, Math.ceil((targetDate.getTime() - now.getTime()) / 86400000));
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="dashboard" />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="dash-content">
        <div class="dash-greeting">
          <h1>Welcome back, <span class="accent">{user.name?.split(' ')[0]}</span></h1>
          <p>Here's your allowance overview for the current program cycle.</p>
        </div>

        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-label">Active Rate</div>
            <div class="metric-value">₱{settings.hourlyRate.toFixed(2)}<span class="metric-unit"> / hr</span></div>
            <div class="metric-sub">Current multiplier · updated weekly</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Target Date</div>
            <div class="metric-value">{daysLeft}<span class="metric-unit"> days</span></div>
            <div class="metric-sub">May 12, 2026 · program deadline</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Your Hours</div>
            <div class="metric-value">{renderedHours.toFixed(2)}<span class="metric-unit"> / {settings.targetHours} hrs</span></div>
            <div class="metric-sub">{clockifyError ? <span class="error-text">{clockifyError}</span> : `Since ${new Date(settings.startDate).toLocaleDateString()}`}</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Team Status</div>
            <div class="metric-value">3<span class="metric-unit"> active</span></div>
            <div class="metric-sub">Developers online this session</div>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">Monthly Breakdown</h2>
          <div class="table-wrapper">
            <table class="breakdown-table">
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Hours Rendered</th>
                  <th>Total Allowance</th>
                </tr>
              </thead>
              <tbody>
                {monthlyData.length > 0 ? (
                  monthlyData.map((item) => (
                    <tr>
                      <td class="month-name">
                        {new Date(item.month + '-02').toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
                      </td>
                      <td class="mono">{item.hours.toFixed(2)} hrs</td>
                      <td class="mono allowance-val">₱{(item.hours * settings.hourlyRate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colspan="3" class="empty-state">No time entries found for the selected period.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        <div class="activity-section">
          <h2 class="section-title">Recent Activity</h2>
          <div class="activity-list">
            <div class="activity-item">
              <div class="activity-dot"></div>
              <div class="activity-content">
                <span class="activity-text">Authenticated via Google OAuth</span>
                <span class="activity-time">Just now</span>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot"></div>
              <div class="activity-content">
                <span class="activity-text">{clockifyError ? 'Clockify sync failed' : 'Clockify data synced successfully'}</span>
                <span class="activity-time">{clockifyError ? 'Check credentials' : 'Live'}</span>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot muted"></div>
              <div class="activity-content">
                <span class="activity-text">Program cycle started</span>
                <span class="activity-time">System event</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 20%; left: 55%; transform: translateX(-50%); width: 560px; height: 360px; background: radial-gradient(ellipse, rgba(99,102,241,.08) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  #dash-content { position: relative; z-index: 1; max-width: 900px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  .dash-greeting { margin-bottom: 32px; }
  .dash-greeting h1 { font-size: 28px; font-weight: 700; color: #f1f5f9; margin-bottom: 6px; }
  .dash-greeting p { font-size: 14px; color: rgba(148,163,184,.7); }
  .accent { background: linear-gradient(135deg,#818cf8,#c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 16px; margin-bottom: 36px; }
  .metric-card { background: rgba(13,14,26,.8); border: 1px solid rgba(99,102,241,.16); border-radius: 14px; padding: 20px 22px; transition: border-color .2s, transform .2s; }
  .metric-card:hover { border-color: rgba(99,102,241,.35); transform: translateY(-2px); }
  .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: rgba(148,163,184,.55); margin-bottom: 10px; }
  .metric-value { font-size: 28px; font-weight: 700; color: #e2e8f0; letter-spacing: -.02em; line-height: 1; }
  .metric-unit { font-size: 13px; font-weight: 400; color: rgba(148,163,184,.6); }
  .metric-sub { font-size: 11px; color: rgba(100,116,139,.65); margin-top: 8px; }
  .section-title { font-size: 15px; font-weight: 600; color: rgba(165,180,252,.75); letter-spacing: .04em; margin-bottom: 16px; }
  .activity-list { display: flex; flex-direction: column; gap: 0; }
  .activity-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: rgba(13,14,26,.6); border: 1px solid rgba(99,102,241,.1); border-bottom: none; transition: background .15s; }
  .activity-item:first-child { border-radius: 12px 12px 0 0; }
  .activity-item:last-child { border-radius: 0 0 12px 12px; border-bottom: 1px solid rgba(99,102,241,.1); }
  .activity-item:hover { background: rgba(99,102,241,.06); }
  .activity-dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,.4); flex-shrink: 0; }
  .activity-dot.muted { background: rgba(100,116,139,.4); box-shadow: none; }
  .activity-content { display: flex; justify-content: space-between; flex: 1; align-items: center; }
  .activity-text { font-size: 13px; color: #cbd5e1; }
  .activity-time { font-size: 11px; color: rgba(100,116,139,.6); font-family: 'JetBrains Mono', monospace; }
  .error-text { color: #f87171; }

  .activity-section { margin-bottom: 32px; }
  .table-wrapper { 
    background: rgba(13,14,26,.8); 
    border: 1px solid rgba(99,102,241,.16); 
    border-radius: 14px; 
    overflow: hidden;
  }
  .breakdown-table { width: 100%; border-collapse: collapse; text-align: left; }
  .breakdown-table th { 
    padding: 14px 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; 
    letter-spacing: .05em; color: rgba(165,180,252,.6); border-bottom: 1px solid rgba(99,102,241,.1);
    background: rgba(99,102,241,.03);
  }
  .breakdown-table td { padding: 16px 20px; font-size: 14px; color: #cbd5e1; border-bottom: 1px solid rgba(99,102,241,.05); }
  .breakdown-table tr:last-child td { border-bottom: none; }
  .breakdown-table tr:hover { background: rgba(99,102,241,.02); }
  
  .month-name { font-weight: 600; color: #f1f5f9; }
  .mono { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .allowance-val { color: #34d399; font-weight: 600; }
  .empty-state { text-align: center; padding: 32px; color: rgba(148,163,184,.5); font-size: 13px; }

  @media (max-width: 640px) { #portal-main { margin-left: 0; padding: 24px 16px; } .metrics-grid { grid-template-columns: 1fr; } }
</style>
