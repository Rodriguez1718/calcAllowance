---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings, DEFAULT_SETTINGS } from '../lib/settings';
import { getManualEntries } from '../lib/entries';
import { getClockifyUser, getRenderedHours, getStudentProgress } from '../lib/clockify';
import { formatHMS } from '../lib/utils';
import { groupEntries } from '../lib/grouping';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings(user.id);

// Role-based redirect
if (settings.role === 'coordinator') {
  return Astro.redirect('/coordinator');
}

// Calculate Total Progress using the Unified Sync Engine
const renderedHours = await getStudentProgress(user.id, user.email, settings.startDate);

// Fetch detailed entry breakdown for the chart/list
let allRawEntries: { date: string, durationSeconds: number }[] = [];
try {
  const clockifyUser = await getClockifyUser(user.email);
  if (clockifyUser) {
    const clockifyData = await getRenderedHours(clockifyUser.id, settings.startDate);
    allRawEntries = [...clockifyData.entries];
  }
} catch (e) {}

// Always add manual entries to the breakdown
const manualEntries = await getManualEntries(user.id);
allRawEntries = [
  ...allRawEntries,
  ...manualEntries
    .filter(e => new Date(e.date) >= new Date(settings.startDate))
    .map(e => ({ date: e.date, durationSeconds: e.durationSeconds }))
];

const grouped = groupEntries(allRawEntries, settings.paySchedule);
const monthlyData = grouped.map(item => ({
  label: item.label,
  rendered: item.totalSeconds / 3600,
  earnings: (item.totalSeconds / 3600) * settings.hourlyRate
}));

const totalEarnings = renderedHours * settings.hourlyRate;
const progressPercent = Math.min(100, (renderedHours / (settings.targetHours || 1)) * 100);

// Calculate Estimated Finish Date
const remainingHours = Math.max(0, settings.targetHours - renderedHours);
let avgHoursPerDay = 8; // Default

if (allRawEntries.length > 0) {
  // Calculate average from last 7 unique days of logs
  const dailyTotals: Record<string, number> = {};
  allRawEntries.forEach(e => {
    dailyTotals[e.date] = (dailyTotals[e.date] || 0) + (e.durationSeconds / 3600);
  });
  const recentDays = Object.values(dailyTotals).slice(-7);
  if (recentDays.length > 0) {
    avgHoursPerDay = recentDays.reduce((a, b) => a + b, 0) / recentDays.length;
    if (avgHoursPerDay < 1) avgHoursPerDay = 8; // Fallback if average is too low
  }
}

const workDaysRemaining = Math.ceil(remainingHours / avgHoursPerDay);
let estimatedFinishDate = new Date();
let daysAdded = 0;
while (daysAdded < workDaysRemaining) {
  estimatedFinishDate.setDate(estimatedFinishDate.getDate() + 1);
  // Skip weekends (0 is Sunday, 6 is Saturday)
  if (estimatedFinishDate.getDay() !== 0 && estimatedFinishDate.getDay() !== 6) {
    daysAdded++;
  }
}

const finishDateStr = estimatedFinishDate.toLocaleDateString('en-US', { 
  month: 'short', 
  day: 'numeric', 
  year: 'numeric' 
});
---

<Layout title="Dashboard">
  <Header user={user} />
  
  <div id="portal-body">
    <Sidebar user={user} activeTab="dashboard" role={settings.role} />
    
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>

      {settings.setupComplete === false && (
        <div id="setup-wizard-overlay" class="modal-overlay">
          <div class="setup-card">
            <div class="setup-header">
              <h2>Welcome to <span class="accent">Internship Portal</span></h2>
              <p>Let's get your profile set up to start tracking your progress.</p>
            </div>
            
            <form action="/api/settings" method="POST" class="setup-form">
              <input type="hidden" name="setupComplete" value="true" />
              <input type="hidden" name="redirect" value="/dashboard" />
              <input type="hidden" name="inviteCode" id="generated-invite" value="" />
              
              <div class="role-selector">
                <label class="role-option">
                  <input type="radio" name="role" value="student" checked />
                  <div class="role-content">
                    <span class="role-title">I am a Student</span>
                    <span class="role-desc">Track OJT hours and manage allowance.</span>
                  </div>
                </label>
                <label class="role-option">
                  <input type="radio" name="role" value="coordinator" />
                  <div class="role-content">
                    <span class="role-title">I am a Coordinator</span>
                    <span class="role-desc">Manage students and monitor their progress.</span>
                  </div>
                </label>
              </div>

              <div id="student-fields" class="setup-grid">
                <div class="setup-column">
                  <div class="form-group">
                    <label>Coordinator Invite Code (Optional)</label>
                    <input type="text" name="coordinatorInvite" placeholder="Enter 6-char code" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Internship Program</label>
                    <input type="text" name="program" placeholder="e.g. BS Information Technology" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" name="startDate" value={settings.startDate} required />
                  </div>
                  <div class="form-group">
                    <label>Target Hours</label>
                    <input type="number" name="targetHours" value={settings.targetHours} required />
                  </div>
                </div>

                <div class="setup-column">
                  <div class="form-group">
                    <label>Cooperating Agency / Company</label>
                    <input type="text" name="hostCompany" placeholder="Company Name" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Supervisor Name</label>
                    <input type="text" name="supervisor" placeholder="Full Name" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Hourly Rate (₱)</label>
                    <input type="number" name="hourlyRate" value={settings.hourlyRate} required />
                  </div>
                  <div class="form-group">
                    <label>Pay Schedule</label>
                    <select name="paySchedule" class="setup-select">
                      <option value="weekly">Weekly</option>
                      <option value="semi-monthly">Semi-monthly (15/30)</option>
                      <option value="monthly" selected>Monthly</option>
                    </select>
                  </div>
                </div>
              </div>

              <div id="coordinator-fields" style="display: none;">
                <div class="info-note">
                  <p>As a coordinator, you'll manage your students via a custom dashboard and unique invite code.</p>
                </div>
              </div>
              
              <button type="submit" class="btn-setup">Save & Initialize Dashboard</button>
            </form>

            <script is:inline>
              const roleRadios = document.querySelectorAll('input[name="role"]');
              const studentFields = document.getElementById('student-fields');
              const coordinatorFields = document.getElementById('coordinator-fields');
              const inviteInput = document.getElementById('generated-invite');

              roleRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                  if (e.target.value === 'coordinator') {
                    studentFields.style.display = 'none';
                    coordinatorFields.style.display = 'block';
                    if (!inviteInput.value) {
                      inviteInput.value = Math.random().toString(36).substring(2, 8).toUpperCase();
                    }
                    studentFields.querySelectorAll('input[required]').forEach(i => i.required = false);
                  } else {
                    studentFields.style.display = 'grid';
                    coordinatorFields.style.display = 'none';
                    studentFields.querySelectorAll('input').forEach(i => {
                       if (i.name !== 'coordinatorInvite') i.required = true;
                    });
                  }
                });
              });
            </script>
          </div>
        </div>
      )}

      <div id="dash-content" class="content-center">
        <div class="dashboard-header">
          <div class="header-main">
            <h1>Welcome back, <span class="accent">{user.name}</span></h1>
            <p>Here's your current internship status and progress tracker.</p>
          </div>
          <div class="header-date">
            <span class="date-label">TODAY</span>
            <span class="date-value">{new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>

        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-info">
              <span class="metric-label">Hours Rendered</span>
              <div class="metric-value">{renderedHours.toFixed(2)} <span class="unit">/ {settings.targetHours}h</span></div>
            </div>
            <div class="metric-progress">
              <div class="progress-track">
                <div class={`progress-fill ${progressPercent >= 100 ? 'success' : ''}`} style={`width: ${progressPercent}%`}></div>
              </div>
              <div class="progress-status">
                <span>{progressPercent >= 100 ? 'Completed' : 'In Progress'}</span>
                <span class="percent-val">{progressPercent.toFixed(2)}%</span>
              </div>
            </div>
          </div>

          <div class={`metric-card highlight-card ${renderedHours > settings.targetHours ? 'overtime' : ''}`}>
            <div class="metric-info">
              <span class="metric-label">{renderedHours > settings.targetHours ? 'Excess Time' : 'Remaining Time'}</span>
              <div class="metric-value">
                {renderedHours > settings.targetHours ? '+' : ''}
                {formatHMS(Math.abs((settings.targetHours * 3600) - (renderedHours * 3600)))}
              </div>
              <span class="metric-subtext">
                {renderedHours >= settings.targetHours 
                  ? 'Goal reached! Every hour now is extra credit.' 
                  : `Est. Finish: ${finishDateStr}`}
              </span>
            </div>
          </div>

          <div class="metric-card company-summary">
            <div class="company-header-mini">
              <div class="company-info-mini">
                <span class="metric-label">Cooperating Agency / Company</span>
                <div class="metric-value-mini text-truncate">{settings.hostCompany || 'Not set'}</div>
              </div>
            </div>
            <div class="company-quick-details">
              <div class="quick-row">
                <span class="q-label">Supervisor:</span>
                <span class="q-value">{settings.supervisor || 'Not set'}</span>
              </div>
              <div class="quick-row">
                <span class="q-label">Rate:</span>
                <span class="q-value">₱{settings.hourlyRate}/hr</span>
              </div>
            </div>
          </div>
        </div>

        <div class="full-grid">
          <section class="earnings-breakdown">
            <div class="section-header">
              <h2>Earnings <span class="accent">Breakdown</span></h2>
              <div class="total-earnings-summary">
                <span class="summary-label">Total Estimated:</span>
                <span class="summary-value">₱ {totalEarnings.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
              </div>
            </div>
            <div class="breakdown-list">
              {monthlyData.map(item => (
                <div class="breakdown-item">
                  <div class="item-main">
                    <span class="item-label">{item.label}</span>
                    <span class="item-hours">{item.rendered.toFixed(2)} hours rendered</span>
                  </div>
                  <div class="item-value">₱ {item.earnings.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
                </div>
              ))}
            </div>
          </section>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; padding: 40px; position: relative; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(237, 102, 33, .04) 1px, transparent 1px), linear-gradient(90deg, rgba(237, 102, 33, .04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; }
  
  #dash-content { position: relative; z-index: 1; max-width: 1000px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  .dashboard-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
  .header-main h1 { font-size: 32px; font-weight: 700; color: #fff; letter-spacing: -0.02em; }
  .accent { background: var(--ntv-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .header-main p { color: var(--text-secondary); font-size: 14px; margin-top: 4px; }
  .header-date { text-align: right; }
  .date-label { display: block; font-size: 10px; font-weight: 800; color: var(--ntv-orange); letter-spacing: 0.1em; }
  .date-value { color: #fff; font-size: 14px; font-weight: 600; }

  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 40px; }
  .metric-card { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 20px; padding: 24px; display: flex; flex-direction: column; gap: 16px; transition: 0.3s; }
  .metric-card:hover { border-color: rgba(237, 102, 33, 0.3); transform: translateY(-2px); }
  
  .highlight-card { border-color: rgba(96, 165, 250, 0.4); background: linear-gradient(145deg, var(--card-bg), rgba(96, 165, 250, 0.05)); box-shadow: 0 4px 20px rgba(96, 165, 250, 0.1); }
  .highlight-card .metric-label { color: #60a5fa; }
  .highlight-card.overtime { border-color: rgba(52, 211, 153, 0.4); background: linear-gradient(145deg, var(--card-bg), rgba(52, 211, 153, 0.05)); box-shadow: 0 4px 20px rgba(52, 211, 153, 0.1); }
  .highlight-card.overtime .metric-label { color: #34d399; }
  .highlight-card.overtime b { color: #34d399; }
  
  .metric-info { display: flex; flex-direction: column; gap: 8px; }
  
  .company-summary { gap: 12px !important; padding: 20px !important; }
  .company-header-mini { display: flex; align-items: center; gap: 12px; }
  .company-logo-mini { width: 36px; height: 36px; background: var(--ntv-gradient); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 800; color: #fff; }
  .company-info-mini { flex: 1; min-width: 0; }
  .metric-value-mini { font-size: 16px; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .company-quick-details { display: flex; flex-direction: column; gap: 6px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.05); }
  .quick-row { display: flex; justify-content: space-between; font-size: 11px; }
  .q-label { color: var(--text-secondary); }
  .q-value { color: #fff; font-weight: 600; }

  .metric-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
  .metric-icon.hours { background: rgba(237, 102, 33, 0.1); color: var(--ntv-orange); }
  .metric-icon.remaining { background: rgba(96, 165, 250, 0.1); color: #60a5fa; }
  .metric-label { font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
  .metric-value { font-size: 24px; font-weight: 700; color: #fff; }
  .metric-subtext { font-size: 11px; color: var(--text-secondary); margin-top: -4px; display: block; }
  .metric-subtext b { color: #60a5fa; font-weight: 600; }
  .unit { font-size: 14px; color: var(--text-secondary); font-weight: 500; }

  .progress-track { width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--ntv-gradient); border-radius: 3px; transition: width 1s ease-out; }
  .progress-fill.success { background: linear-gradient(90deg, #10b981, #34d399); }
  .progress-status { display: flex; justify-content: space-between; margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--text-secondary); }
  .percent-val { color: var(--ntv-orange); font-weight: 800; font-size: 12px; }

  .full-grid { width: 100%; }
  
  .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .section-header h2 { font-size: 18px; font-weight: 600; color: #fff; }
  .pay-tag { font-size: 10px; font-weight: 800; padding: 4px 10px; background: rgba(237, 102, 33, 0.1); color: var(--ntv-orange); border-radius: 20px; }

  .total-earnings-summary { text-align: right; }
  .summary-label { display: block; font-size: 10px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; }
  .summary-value { font-size: 18px; font-weight: 700; color: #fff; }

  .earnings-breakdown { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 24px; padding: 24px; }
  .breakdown-list { display: flex; flex-direction: column; gap: 12px; margin-top: 16px; }
  .breakdown-item { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; transition: 0.2s; }
  .breakdown-item:hover { background: rgba(255,255,255,0.05); transform: translateX(4px); }
  .item-label { display: block; font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 4px; }
  .item-hours { font-size: 12px; color: var(--text-secondary); }
  .item-value { font-size: 16px; font-weight: 700; color: var(--ntv-orange); }

  .company-card { background: var(--card-bg); border: 1px solid var(--border-subtle); border-radius: 24px; padding: 24px; display: flex; flex-direction: column; gap: 24px; }
  .company-header { display: flex; align-items: center; gap: 16px; }
  .company-logo { width: 48px; height: 48px; background: var(--ntv-gradient); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: #fff; }
  .company-info h3 { font-size: 16px; font-weight: 600; color: #fff; }
  .company-info span { font-size: 12px; color: var(--text-secondary); }
  
  .company-details { display: flex; flex-direction: column; gap: 16px; }
  .detail-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .detail-row:last-child { border-bottom: none; }
  .d-label { font-size: 12px; color: var(--text-secondary); }
  .d-value { font-size: 13px; font-weight: 600; color: #fff; }

  /* Setup Wizard Styles */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .setup-card { background: #0d1421; border: 1px solid rgba(237, 102, 33, 0.3); border-radius: 24px; width: 100%; max-width: 800px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
  .setup-header { text-align: center; margin-bottom: 32px; }
  .setup-header h2 { font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .setup-header p { color: var(--text-secondary); font-size: 14px; }
  
  .role-selector { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px; }
  .role-option { cursor: pointer; }
  .role-option input { display: none; }
  .role-content { padding: 20px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; transition: 0.2s; }
  .role-option input:checked + .role-content { background: rgba(237, 102, 33, 0.1); border-color: var(--ntv-orange); }
  .role-title { display: block; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .role-desc { font-size: 11px; color: var(--text-secondary); line-height: 1.4; }

  .setup-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .form-group label { font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
  .setup-input, .setup-select, input[type="date"], input[type="number"] { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px 16px; color: #fff; font-size: 14px; font-family: inherit; outline: none; transition: 0.2s; }
  .setup-input:focus, .setup-select:focus { border-color: var(--ntv-orange); background: rgba(237, 102, 33, 0.05); }
  .setup-select option { background: #0d1421; color: white; }
  
  .info-note { background: rgba(96, 165, 250, 0.1); border: 1px solid rgba(96, 165, 250, 0.2); padding: 16px; border-radius: 12px; color: #93c5fd; font-size: 13px; text-align: center; }
  
  .btn-setup { width: 100%; margin-top: 24px; background: var(--ntv-gradient); color: #fff; border: none; border-radius: 12px; padding: 16px; font-size: 15px; font-weight: 700; cursor: pointer; transition: 0.2s; }
  .btn-setup:hover { filter: brightness(1.1); transform: translateY(-1px); box-shadow: 0 8px 25px rgba(237, 102, 33, 0.3); }

  @media (max-width: 900px) {
    #portal-main { margin-left: 0; padding: 20px; }
    .dashboard-header { flex-direction: column; gap: 20px; }
    .dashboard-grid { grid-template-columns: 1fr; }
    .setup-grid { grid-template-columns: 1fr; }
    .setup-card { padding: 24px; }
  }
</style>
