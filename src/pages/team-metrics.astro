---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getClockifyUser, getDailyDTR } from '../lib/clockify';
import { getAppSettings } from '../lib/settings';
import { getManualEntries } from '../lib/entries';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings(user.id);
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

// Get month from query or default to current
const month = parseInt(Astro.url.searchParams.get('month') || currentMonth.toString());
const year = parseInt(Astro.url.searchParams.get('year') || currentYear.toString());

const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);

let dtrData: any = {};
let totalMonthSeconds = 0;
let clockifyError = null;
let isUsingManual = false;

const formatTo12hr = (timeStr: string) => {
  if (!timeStr) return '';
  const [h, m] = timeStr.split(':').map(Number);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const hour = h % 12 || 12;
  return `${hour}:${String(m).padStart(2, '0')} ${ampm}`;
};

if (isClockifySet) {
  try {
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      dtrData = await getDailyDTR(clockifyUser.id, year, month);
      totalMonthSeconds = Object.values(dtrData).reduce((acc: number, day: any) => acc + day.totalSeconds, 0);
    } else {
      isUsingManual = true;
    }
  } catch (err) {
    clockifyError = (err as Error).message;
    isUsingManual = true;
  }
} else {
  isUsingManual = true;
}

if (isUsingManual) {
  // Manual DTR Fallback
  const manualEntries = await getManualEntries(user.id);
  const daysInMonth = new Date(year, month, 0).getDate();
  
  // Initialize empty DTR for the whole month
  for (let i = 1; i <= daysInMonth; i++) {
    dtrData[i] = { amIn: '', amOut: '', pmIn: '', pmOut: '', totalSeconds: 0 };
  }

  const filtered = manualEntries.filter(e => {
    const d = new Date(e.date);
    return d.getMonth() + 1 === month && d.getFullYear() === year;
  });

  filtered.forEach(e => {
    const day = new Date(e.date).getDate();
    const [h, m] = e.startTime.split(':').map(Number);
    const isAM = h < 12 || (h === 12 && m < 30);
    
    if (isAM) {
      if (!dtrData[day].amIn || e.startTime < dtrData[day].amIn) dtrData[day].amIn = formatTo12hr(e.startTime);
      if (!dtrData[day].amOut || e.endTime > dtrData[day].amOut) dtrData[day].amOut = formatTo12hr(e.endTime);
    } else {
      if (!dtrData[day].pmIn || e.startTime < dtrData[day].pmIn) dtrData[day].pmIn = formatTo12hr(e.startTime);
      if (!dtrData[day].pmOut || e.endTime > dtrData[day].pmOut) dtrData[day].pmOut = formatTo12hr(e.endTime);
    }
    dtrData[day].totalSeconds += e.durationSeconds;
  });

  totalMonthSeconds = Object.values(dtrData).reduce((acc: number, day: any) => acc + day.totalSeconds, 0);
}

const formatDuration = (seconds: number) => {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return `${h}:${m.toString().padStart(2, '0')}`;
};

const monthName = new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long' }).toUpperCase();
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="team-metrics" />

    <main id="portal-main">
      <div class="no-print actions-bar">
        <div class="month-selector">
          <form method="GET" class="selector-form">
            <select name="month" onchange="this.form.submit()">
              {Array.from({length: 12}).map((_, i) => (
                <option value={i+1} selected={month === i+1}>{new Date(0, i).toLocaleString('en-US', {month: 'long'})}</option>
              ))}
            </select>
            <select name="year" onchange="this.form.submit()">
              {[2024, 2025, 2026].map(y => (
                <option value={y} selected={year === y}>{y}</option>
              ))}
            </select>
          </form>
        </div>
        <button onclick="window.print()" class="print-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print / Download DTR
        </button>
      </div>

      <div class="dtr-container" id="dtr-sheet">
        <header class="dtr-header">
          <div class="dtr-title">OJT DAILY TIME RECORD</div>
          
          <div class="dtr-info-grid">
            <div class="info-item">
              <span class="label">OJT Student:</span>
              <span class="value underline">{user.name}</span>
            </div>
            <div class="info-item">
              <span class="label">Program:</span>
              <span class="value underline">BS Information Technology</span>
            </div>
            <div class="info-item">
              <span class="label">Host Company:</span>
              <span class="value underline">N-Compass TV</span>
            </div>
            <div class="info-item">
              <span class="label">Period:</span>
              <span class="value underline">Month/Year: {monthName} {year}</span>
            </div>
            <div class="info-item">
              <span class="label">Supervisor:</span>
              <span class="value underline">Ms. Jessica Cordero</span>
            </div>
            <div class="info-item highlight">
              <span class="label">Total Hours:</span>
              <span class="value">{formatDuration(totalMonthSeconds)}</span>
            </div>
          </div>
        </header>

        <table class="dtr-table">
          <thead>
            <tr>
              <th rowspan="2">Date</th>
              <th colspan="2">AM</th>
              <th colspan="2">PM</th>
              <th rowspan="2">Total Hrs</th>
            </tr>
            <tr>
              <th>In</th>
              <th>Out</th>
              <th>In</th>
              <th>Out</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(dtrData).map(([day, data]: [string, any]) => (
              <tr class={data.totalSeconds === 0 ? 'weekend-row' : ''}>
                <td class="date-col">{day}</td>
                <td>{data.amIn}</td>
                <td>{data.amOut}</td>
                <td>{data.pmIn}</td>
                <td>{data.pmOut}</td>
                <td class="total-col">{data.totalSeconds > 0 ? formatDuration(data.totalSeconds) : ''}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <footer class="dtr-footer">
          <div class="certification">
            Student Certification: I certify that I rendered the above service.
          </div>
          <div class="sig-lines">
            <div class="sig-group">
              <span class="sig-label">Signature:</span>
              <div class="sig-underline"></div>
            </div>
            <div class="sig-group">
              <span class="sig-label">Date:</span>
              <div class="sig-underline"></div>
            </div>
          </div>

          <div class="approval">
            VERIFIED & APPROVED:
          </div>
          <div class="sig-lines">
            <div class="sig-group full">
              <span class="sig-label">Supervisor Signature:</span>
              <div class="sig-underline"></div>
            </div>
            <div class="sig-group">
              <span class="sig-label">Date:</span>
              <div class="sig-underline"></div>
            </div>
            <div class="sig-group">
              <span class="sig-label">Position:</span>
              <span class="value">Project Manager</span>
            </div>
          </div>
        </footer>
      </div>
    </main>
  </div>
</Layout>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; padding: 40px; position: relative; }

  .actions-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; max-width: 800px; }
  .month-selector select { 
    background: rgba(255,255,255,0.05); 
    border: 1px solid var(--border-subtle); 
    color: white; 
    padding: 8px 12px; 
    border-radius: 6px; 
    outline: none;
    font-size: 14px;
    font-weight: 500;
  }
  
  .month-selector select option {
    background: #1a1a2e;
    color: white;
    padding: 8px;
  }
  
  .print-btn { 
    display: flex; align-items: center; gap: 8px; background: var(--ntv-gradient); color: white; border: none; 
    padding: 10px 18px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s;
  }
  .print-btn:hover { background: var(--ntv-red); transform: translateY(-1px); }

  /* DTR Styling - Matching the Screenshot */
  .dtr-container { 
    background: white; color: black; padding: 40px; width: 800px; margin: 0 auto;
    font-family: Arial, sans-serif; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-radius: 4px;
  }

  .dtr-title { text-align: center; font-size: 20px; font-weight: 700; background: #d1d5db; padding: 8px; border: 2px solid #9ca3af; border-bottom: none; }
  
  .dtr-info-grid { 
    display: grid; grid-template-columns: 1fr 1fr; border: 2px solid #9ca3af; 
    border-top: none; background: #f3f4f6; 
  }
  .info-item { padding: 8px 12px; border-right: 1px solid #9ca3af; border-bottom: 1px solid #9ca3af; font-size: 13px; display: flex; gap: 6px; }
  .info-item:nth-child(even) { border-right: none; }
  .info-item.highlight { background: #e5e7eb; font-weight: 700; }
  .label { font-weight: 600; width: 100px; }
  .underline { text-decoration: underline; }

  .dtr-table { width: 100%; border-collapse: collapse; border: 2px solid #9ca3af; margin-top: -2px; }
  .dtr-table th { background: #d1d5db; border: 1px solid #9ca3af; padding: 6px; font-size: 12px; font-weight: 700; text-align: center; }
  .dtr-table td { border: 1px solid #9ca3af; padding: 4px 8px; font-size: 12px; height: 24px; text-align: center; }
  .date-col { font-weight: 700; background: #f9fafb; width: 50px; }
  .total-col { font-weight: 700; background: #f9fafb; }
  .weekend-row { background: #fef2f2; }

  .dtr-footer { margin-top: 20px; font-size: 12px; }
  .certification { font-weight: 700; margin-bottom: 15px; }
  .approval { font-weight: 700; margin-top: 25px; margin-bottom: 15px; }
  
  .sig-lines { display: flex; gap: 40px; align-items: flex-end; margin-bottom: 15px; }
  .sig-group { display: flex; align-items: flex-end; gap: 8px; }
  .sig-group.full { flex: 1; }
  .sig-underline { border-bottom: 1px solid black; min-width: 150px; height: 18px; }
  .sig-label { font-weight: 700; white-space: nowrap; }

  @media print {
    @page { 
      margin: 0.8cm;
      size: A4 portrait;
    }
    
    /* Hide nav elements */
    #sys-header, #sidebar, .no-print { display: none !important; }
    
    /* Reset layout for print */
    #portal-body { 
      display: block !important; 
      padding: 0 !important; 
      min-height: auto !important; 
    }
    
    #portal-main { 
      margin: 0 !important; 
      padding: 0 !important; 
    }
    
    /* DTR container */
    .dtr-container { 
      width: 100% !important;
      max-width: 100% !important;
      box-shadow: none !important;
      padding: 0 !important;
      margin: 0 !important;
      border-radius: 0 !important;
    }
  }

  @media (max-width: 1000px) {
    .dtr-container { width: 100%; overflow-x: auto; transform: scale(0.9); transform-origin: top left; }
  }
</style>
